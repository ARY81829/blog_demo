<%= form_with(model: post, local: true, html: { multipart: true }) do |form| %>
  <% if post.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(post.errors.count, "Fehler") %> verhinderten das Speichern:</h4>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, "Titel", class: "form-label fw-bold" %>
    <%= form.text_field :title, class: "form-control", placeholder: "Gib einen Titel ein (min. 5 Zeichen)" %>
  </div>

  <div class="mb-3">
    <%= form.label :body, "Inhalt", class: "form-label fw-bold" %>
    <%= form.text_area :body, class: "form-control", rows: 6, placeholder: "Schreibe deinen Beitrag hier..." %>
  </div>

  <div class="mb-3">
    <%= form.label :image, "Bild hinzufügen", class: "form-label fw-bold" %>
    <%= form.file_field :image, class: "form-control" %>
  </div>

  <% if post.persisted? && post.image.attached? %>
    <div class="mb-3 text-center">
      <p class="fw-bold">Aktuelles Bild:</p>
      <%= image_tag post.image.variant(resize_to_fill: [250, 250]), class: "img-thumbnail shadow-sm" %>
    </div>
  <% end %>

  <div class="d-grid gap-2">
    <%= form.submit post.new_record? ? "Beitrag erstellen" : "Änderungen speichern", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
